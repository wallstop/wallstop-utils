#!/usr/bin/env bash
set -euo pipefail

emit_diagnostic() {
  printf '%s\n' "$*" >&2
}

if ! command -v git > /dev/null 2>&1; then
  emit_diagnostic "E_PREPUSH_HOOK_GIT_NOT_AVAILABLE: git is required for hook execution but was not found on PATH."
  exit 1
fi

hook_start_seconds="$SECONDS"

if ! repo_root_stderr_path="$(mktemp 2> /dev/null)"; then
  repo_root_stderr_path="/tmp/wallstop-prepush-repo-root.$$.$RANDOM.err"
fi
set +e
repo_root="$(git rev-parse --show-toplevel 2> "$repo_root_stderr_path")"
repo_root_exit=$?
repo_root_stderr=""
if [[ -f "$repo_root_stderr_path" ]]; then
  repo_root_stderr="$(< "$repo_root_stderr_path")"
fi
rm -f "$repo_root_stderr_path" > /dev/null 2>&1 || true
set -e
if [[ $repo_root_exit -ne 0 || -z "$repo_root" ]]; then
  if [[ $repo_root_exit -eq 0 ]]; then
    repo_root_exit=1
  fi
  repo_root_output="$repo_root"
  if [[ -n "$repo_root_stderr" ]]; then
    if [[ -n "$repo_root_output" ]]; then
      repo_root_output="${repo_root_output}"$'\n'"${repo_root_stderr}"
    else
      repo_root_output="$repo_root_stderr"
    fi
  fi
  git_command="$(command -v git 2> /dev/null || printf '<unresolved>')"
  working_directory="$(pwd 2> /dev/null || printf '<unresolved>')"
  emit_diagnostic "E_PREPUSH_REPO_ROOT_UNAVAILABLE: failed to resolve repository root (exitCode=${repo_root_exit}; workingDirectory=${working_directory}; gitCommand=${git_command}). Git output: ${repo_root_output}"
  exit "$repo_root_exit"
fi
cd "$repo_root"

precommit_home="${repo_root}/.tools/precommit-cli/pre-commit-home"
if mkdir -p "$precommit_home" > /dev/null 2>&1; then
  export PRE_COMMIT_HOME="$precommit_home"
else
  emit_diagnostic "W_PREPUSH_PRECOMMIT_HOME_UNAVAILABLE: unable to create managed PRE_COMMIT_HOME at '${precommit_home}'; pre-commit will use its host default cache."
fi

hook_timeout_helpers_path="${repo_root}/Scripts/Utils/Common/HookTimeout.sh"
if [[ ! -f "$hook_timeout_helpers_path" ]]; then
  emit_diagnostic "E_HOOK_TIMEOUT_HELPER_MISSING: timeout helper file not found at '$hook_timeout_helpers_path'."
  exit 1
fi

# shellcheck source=Scripts/Utils/Common/HookTimeout.sh
. "$hook_timeout_helpers_path"

prepush_timeout_seconds="${WALLSTOP_PREPUSH_TIMEOUT_SECONDS:-1800}"
prepush_recovery_inner_timeout_seconds=30
prepush_recovery_shutdown_buffer_seconds=15
prepush_recovery_setup_slack_seconds=15
minimum_prepush_timeout_seconds=$((prepush_recovery_inner_timeout_seconds + prepush_recovery_shutdown_buffer_seconds + prepush_recovery_setup_slack_seconds))
zero_oid="0000000000000000000000000000000000000000"
resolved_changed_files=()
resolved_changed_file_oids=()
saw_pre_push_ref_update=0
saw_non_head_push_ref=0
changed_file_list_path=""
fast_validation_root_path=""
fast_tool_resolver_loaded=0

trap 'if [[ -n "$changed_file_list_path" ]]; then rm -f "$changed_file_list_path"; fi; if [[ -n "$fast_validation_root_path" ]]; then rm -rf "$fast_validation_root_path"; fi' EXIT

validate_timeout_seconds() {
  local timeout_value="$1"
  local env_name="$2"

  if [[ ! "$timeout_value" =~ ^[0-9]+$ ]] || [[ "$timeout_value" -lt "$minimum_prepush_timeout_seconds" ]]; then
    emit_diagnostic "E_HOOK_TIMEOUT_CONFIG: ${env_name} must be an integer >= ${minimum_prepush_timeout_seconds} seconds (${prepush_recovery_inner_timeout_seconds}s inner recovery timeout plus ${prepush_recovery_shutdown_buffer_seconds}s shutdown buffer plus ${prepush_recovery_setup_slack_seconds}s setup slack; received '${timeout_value}')."
    exit 2
  fi
}

resolve_timeout_command() {
  wallstop_resolve_timeout_command
}

describe_timeout_provider() {
  local timeout_command
  if timeout_command="$(resolve_timeout_command)"; then
    printf '%s\n' "$timeout_command"
    return 0
  fi

  printf '%s\n' "shell-watchdog"
}

runtime_budget_seconds() {
  local label="$1"
  case "$label" in
    "pre-push changed-file pre-commit validation" | "legacy pre-push PowerShell validation")
      printf '%s\n' "${WALLSTOP_PREPUSH_ACTIVE_RUNTIME_BUDGET_SECONDS:-30}"
      ;;
    "pre-push fast gate" | "pre-push fast actionlint" | "pre-push fast actionlint bootstrap")
      printf '%s\n' "${WALLSTOP_PREPUSH_FAST_RUNTIME_BUDGET_SECONDS:-1}"
      ;;
    *)
      printf '%s\n' "${WALLSTOP_PREPUSH_NOOP_RUNTIME_BUDGET_SECONDS:-1}"
      ;;
  esac
}

emit_runtime_budget_warning() {
  local label="$1"
  local elapsed_seconds="$2"
  local budget_seconds
  budget_seconds="$(runtime_budget_seconds "$label")"

  if [[ ! "$budget_seconds" =~ ^[0-9]+$ ]] || [[ "$budget_seconds" -lt 1 ]]; then
    budget_seconds=1
  fi

  if [[ $elapsed_seconds -gt $budget_seconds ]]; then
    emit_diagnostic "W_HOOK_RUNTIME_BUDGET: ${label} took ${elapsed_seconds}s (budget <= ${budget_seconds}s; no-op fast-path target <= 1s)."
  fi
}

emit_recovery_budget_diagnostic() {
  local phase_label="$1"
  local remaining_seconds="$2"
  local required_remaining_seconds="$3"
  local inner_timeout_seconds="$4"
  local elapsed_seconds=$((SECONDS - hook_start_seconds))
  local timeout_provider
  timeout_provider="$(describe_timeout_provider)"

  emit_diagnostic "E_HOOK_TIMEOUT: ${phase_label} has ${remaining_seconds}s remaining, below required recovery budget. configuredTimeoutSeconds=${prepush_timeout_seconds}; elapsedSetupSeconds=${elapsed_seconds}; remainingSeconds=${remaining_seconds}; requiredRemainingSeconds=${required_remaining_seconds}; innerTimeoutSeconds=${inner_timeout_seconds}; minimumInnerTimeoutSeconds=${prepush_recovery_inner_timeout_seconds}; shutdownBufferSeconds=${prepush_recovery_shutdown_buffer_seconds}; setupSlackSeconds=${prepush_recovery_setup_slack_seconds}; timeoutProvider=${timeout_provider}; changedFileCount=${#resolved_changed_files[@]}."
}

run_with_timeout() {
  local timeout_seconds="$1"
  shift
  local label="$1"
  shift
  local phase_start_seconds=$SECONDS
  local caller_errexit_enabled=0
  case "$-" in
    *e*) caller_errexit_enabled=1 ;;
  esac

  local timeout_command
  if timeout_command="$(resolve_timeout_command)"; then
    set +e
    "$timeout_command" -k 2s "${timeout_seconds}s" "$@"
    local command_exit=$?
    if [[ $caller_errexit_enabled -eq 1 ]]; then
      set -e
    else
      set +e
    fi

    if [[ $command_exit -eq 124 || $command_exit -eq 137 ]]; then
      emit_diagnostic "E_HOOK_TIMEOUT: ${label} exceeded ${timeout_seconds}s. Override with WALLSTOP_PREPUSH_TIMEOUT_SECONDS."
    fi

    local elapsed_seconds=$((SECONDS - phase_start_seconds))
    emit_runtime_budget_warning "$label" "$elapsed_seconds"

    return $command_exit
  fi

  emit_diagnostic "W_HOOK_TIMEOUT_UNAVAILABLE: timeout/gtimeout not found; using shell watchdog timeout for '${label}'."

  local timeout_flag_file
  timeout_flag_file="$(mktemp 2> /dev/null || true)"
  if [[ -z "$timeout_flag_file" ]]; then
    timeout_flag_file="/tmp/wallstop-hook-timeout.$$.$RANDOM.flag"
  fi
  rm -f "$timeout_flag_file"

  set +e
  WALLSTOP_TIMEOUT_COMMAND_PID=""
  WALLSTOP_TIMEOUT_COMMAND_PROCESS_GROUP_MODE=""
  wallstop_start_timeout_command "$label" "$@"
  local command_pid="$WALLSTOP_TIMEOUT_COMMAND_PID"
  local command_process_group_mode="$WALLSTOP_TIMEOUT_COMMAND_PROCESS_GROUP_MODE"
  (
    sleep "$timeout_seconds"
    if wallstop_is_timeout_command_alive "$command_pid" "$command_process_group_mode"; then
      : > "$timeout_flag_file"
      wallstop_terminate_timeout_command "$command_pid" "$command_process_group_mode"
    fi
  ) &
  local watchdog_pid=$!

  wait "$command_pid"
  local fallback_exit=$?
  kill "$watchdog_pid" > /dev/null 2>&1 || true
  wait "$watchdog_pid" > /dev/null 2>&1 || true
  wallstop_cleanup_timeout_command_processes "$command_pid" "$command_process_group_mode" "$label"
  if [[ $caller_errexit_enabled -eq 1 ]]; then
    set -e
  else
    set +e
  fi

  if [[ -f "$timeout_flag_file" ]]; then
    rm -f "$timeout_flag_file"
    emit_diagnostic "E_HOOK_TIMEOUT: ${label} exceeded ${timeout_seconds}s. Override with WALLSTOP_PREPUSH_TIMEOUT_SECONDS."
    local elapsed_seconds=$((SECONDS - phase_start_seconds))
    emit_runtime_budget_warning "$label" "$elapsed_seconds"
    return 124
  fi

  rm -f "$timeout_flag_file"
  local elapsed_seconds=$((SECONDS - phase_start_seconds))
  emit_runtime_budget_warning "$label" "$elapsed_seconds"
  return $fallback_exit
}

remaining_timeout_seconds() {
  local phase_label="$1"
  local elapsed_seconds=$((SECONDS - hook_start_seconds))
  local remaining_seconds=$((prepush_timeout_seconds - elapsed_seconds))

  if [[ "$remaining_seconds" -lt 1 ]]; then
    emit_recovery_budget_diagnostic "$phase_label" "$remaining_seconds" 1 0
    return 1
  fi

  printf '%s\n' "$remaining_seconds"
}

validate_timeout_seconds "$prepush_timeout_seconds" "WALLSTOP_PREPUSH_TIMEOUT_SECONDS"

is_truthy() {
  case "${1:-}" in
    1 | true | TRUE | yes | YES | on | ON)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

load_fast_tool_resolver() {
  if [[ "$fast_tool_resolver_loaded" -eq 1 ]]; then
    return 0
  fi

  local fast_tool_resolver_path="${repo_root}/Scripts/Utils/Common/HookFastToolResolver.sh"
  if [[ ! -f "$fast_tool_resolver_path" ]]; then
    emit_diagnostic "E_PREPUSH_FAST_TOOL_RESOLVER_MISSING: fast tool resolver file not found at '$fast_tool_resolver_path'."
    return 1
  fi

  # shellcheck source=Scripts/Utils/Common/HookFastToolResolver.sh
  . "$fast_tool_resolver_path"
  fast_tool_resolver_loaded=1
}

ensure_fast_validation_root() {
  if [[ -n "$fast_validation_root_path" ]]; then
    return 0
  fi

  fast_validation_root_path="$(mktemp -d 2> /dev/null || true)"
  if [[ -z "$fast_validation_root_path" ]]; then
    fast_validation_root_path="/tmp/wallstop-prepush-fast.$$.$RANDOM"
    if ! mkdir -p "$fast_validation_root_path" > /dev/null 2>&1; then
      emit_diagnostic "E_PREPUSH_FAST_TEMP_UNAVAILABLE: failed to create temporary directory for pushed-blob validation."
      return 1
    fi
  fi
}

extract_prepush_blob_for_fast_validation() {
  local local_oid="$1"
  local changed_file="$2"
  local target_path
  local target_dir

  if ! git cat-file -e "${local_oid}:${changed_file}" > /dev/null 2>&1; then
    return 0
  fi

  if ! ensure_fast_validation_root; then
    return 1
  fi

  target_path="${fast_validation_root_path}/${local_oid}/${changed_file}"
  target_dir="${target_path%/*}"
  if [[ "$target_dir" != "$target_path" ]]; then
    if ! mkdir -p "$target_dir" > /dev/null 2>&1; then
      emit_diagnostic "E_PREPUSH_FAST_TEMP_UNAVAILABLE: failed to create temporary parent directory for pushed-blob validation. file=${changed_file}"
      return 1
    fi
  fi

  if ! git show "${local_oid}:${changed_file}" > "$target_path"; then
    emit_diagnostic "E_PREPUSH_FAST_BLOB_EXTRACT_FAILED: failed to extract pushed blob for validation. file=${changed_file} localOid=${local_oid}"
    return 1
  fi

  printf '%s\n' "$target_path"
}

validate_prepush_shell_blob() {
  local local_oid="$1"
  local changed_file="$2"

  if ! git cat-file -e "${local_oid}:${changed_file}" > /dev/null 2>&1; then
    return 0
  fi

  if git cat-file blob "${local_oid}:${changed_file}" | bash -n; then
    return 0
  fi

  emit_diagnostic "E_PREPUSH_FAST_SHELL_PARSE_FAILED: bash syntax check failed for pushed blob. file=${changed_file} localOid=${local_oid}"
  return 1
}

# Ensures the repo-managed actionlint asset is bootstrapped. Returns 0 only when the asset
# resolves to a non-empty path. The resolved path is kept local so callers do not depend on
# a dynamic-scope side effect; callers re-resolve explicitly (see run_fast_prepush_gate).
ensure_prepush_fast_actionlint_tools() {
  if ! load_fast_tool_resolver; then
    return 1
  fi

  local resolved_actionlint_path
  resolved_actionlint_path="$(wallstop_resolve_managed_fast_tool "$repo_root" ".tools/native-quality" "actionlint" || true)"

  if [[ -n "$resolved_actionlint_path" ]]; then
    return 0
  fi

  if command -v pwsh > /dev/null 2>&1; then
    local remaining_seconds
    if ! remaining_seconds="$(remaining_timeout_seconds "pre-push fast actionlint bootstrap")"; then
      return 124
    fi

    set +e
    run_with_timeout "$remaining_seconds" "pre-push fast actionlint bootstrap" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Quality/Invoke-NativeQualityChecks.ps1" -Tool actionlint -EnsureOnly
    local ensure_exit=$?
    set -e
    if [[ $ensure_exit -ne 0 ]]; then
      return "$ensure_exit"
    fi

    resolved_actionlint_path="$(wallstop_resolve_managed_fast_tool "$repo_root" ".tools/native-quality" "actionlint" || true)"
    if [[ -n "$resolved_actionlint_path" ]]; then
      return 0
    fi
  fi

  emit_diagnostic "E_PREPUSH_FAST_NATIVE_TOOL_MISSING: repo-managed actionlint asset is unavailable and automated bootstrap did not make it available. Run validation preflight."
  return 1
}

run_fast_prepush_gate() {
  local phase_start_seconds=$SECONDS
  local file
  local local_oid
  local extracted_file
  local index
  local run_workflow_lint=0
  local workflow_targets=()

  if is_truthy "${WALLSTOP_PREPUSH_FAST_WORKFLOW_LINT:-0}"; then
    run_workflow_lint=1
  fi

  for index in "${!resolved_changed_files[@]}"; do
    file="${resolved_changed_files[$index]}"
    local_oid="${resolved_changed_file_oids[$index]}"
    [[ -n "$file" ]] || continue
    [[ -n "$local_oid" ]] || continue

    case "$file" in
      Scripts/*.sh | .devcontainer/*.sh | .githooks/pre-commit | .githooks/pre-push)
        if ! validate_prepush_shell_blob "$local_oid" "$file"; then
          return 1
        fi
        ;;
      .github/workflows/*.yml | .github/workflows/*.yaml)
        if [[ "$run_workflow_lint" -ne 1 ]]; then
          continue
        fi
        if ! extracted_file="$(extract_prepush_blob_for_fast_validation "$local_oid" "$file")"; then
          return 1
        fi
        [[ -n "$extracted_file" ]] || continue
        workflow_targets+=("$extracted_file")
        ;;
    esac
  done

  if [[ ${#workflow_targets[@]} -gt 0 ]]; then
    set +e
    ensure_prepush_fast_actionlint_tools
    local ensure_actionlint_exit=$?
    set -e
    if [[ $ensure_actionlint_exit -ne 0 ]]; then
      return "$ensure_actionlint_exit"
    fi

    # Resolve the executable explicitly (ensure_* loaded the resolver) instead of relying on
    # a dynamic-scope side effect, then refuse to invoke an empty path so a resolver
    # regression can never exec an empty string under run_with_timeout.
    local actionlint_path
    actionlint_path="$(wallstop_resolve_managed_fast_tool "$repo_root" ".tools/native-quality" "actionlint" || true)"
    if [[ -z "$actionlint_path" ]]; then
      emit_diagnostic "E_PREPUSH_FAST_ACTIONLINT_PATH_EMPTY: actionlint resolved to an empty path after bootstrap reported success; refusing to invoke an empty executable. Run validation preflight."
      return 1
    fi

    local remaining_seconds
    if ! remaining_seconds="$(remaining_timeout_seconds "pre-push fast actionlint")"; then
      return 124
    fi

    run_with_timeout "$remaining_seconds" "pre-push fast actionlint" "$actionlint_path" -shellcheck "" -pyflakes "" "${workflow_targets[@]}"
    return $?
  fi

  return 0
}

required_precommit_version() {
  local requirements_path="${repo_root}/requirements.txt"
  local version=""

  if [[ -f "$requirements_path" ]]; then
    version="$(awk -F'==' '/^[[:space:]]*pre-commit==/ { gsub(/[[:space:]].*$/, "", $2); print $2; exit }' "$requirements_path")"
  fi

  if [[ -n "$version" ]]; then
    printf '%s\n' "$version"
  else
    printf '%s\n' "<pinned-version-from-requirements.txt>"
  fi
}

print_precommit_bootstrap_guidance() {
  local pinned_version
  pinned_version="$(required_precommit_version)"

  emit_diagnostic "  pipx install pre-commit==${pinned_version}"
  emit_diagnostic "    or via venv:"
  emit_diagnostic "      python3 -m venv ~/.local/venvs/pre-commit"
  emit_diagnostic "      ~/.local/venvs/pre-commit/bin/pip install --requirement requirements.txt"
  emit_diagnostic "      mkdir -p ~/.local/bin"
  emit_diagnostic "      ln -sf ~/.local/venvs/pre-commit/bin/pre-commit ~/.local/bin/pre-commit"
  emit_diagnostic "      export PATH=\"\$HOME/.local/bin:\$PATH\""
}

append_changed_files_from_output() {
  local local_oid="$1"
  local changed_file_output="$2"
  local changed_file

  while IFS= read -r changed_file; do
    if [[ -n "$changed_file" ]]; then
      resolved_changed_files+=("$changed_file")
      resolved_changed_file_oids+=("$local_oid")
    fi
  done <<< "$changed_file_output"
}

append_diff_changed_files() {
  local baseline_oid="$1"
  local local_oid="$2"
  local diff_output
  local diff_stderr
  local diff_stderr_path
  local diff_exit

  if ! diff_stderr_path="$(mktemp 2> /dev/null)"; then
    diff_stderr_path="/tmp/wallstop-prepush-diff.$$.$RANDOM.err"
  fi
  set +e
  diff_output="$(git diff --name-only --diff-filter=ACMRD "${baseline_oid}..${local_oid}" -- 2> "$diff_stderr_path")"
  diff_exit=$?
  diff_stderr=""
  if [[ -f "$diff_stderr_path" ]]; then
    diff_stderr="$(< "$diff_stderr_path")"
  fi
  rm -f "$diff_stderr_path" > /dev/null 2>&1 || true
  set -e

  if [[ $diff_exit -ne 0 ]]; then
    local diff_diagnostic_output="$diff_output"
    if [[ -n "$diff_stderr" ]]; then
      if [[ -n "$diff_diagnostic_output" ]]; then
        diff_diagnostic_output="${diff_diagnostic_output}"$'\n'"${diff_stderr}"
      else
        diff_diagnostic_output="$diff_stderr"
      fi
    fi
    emit_diagnostic "E_PREPUSH_CHANGED_FILE_DISCOVERY_FAILED: failed to resolve changed files for '${baseline_oid}..${local_oid}' (exitCode=${diff_exit}). Git output: ${diff_diagnostic_output}"
    return "$diff_exit"
  fi

  append_changed_files_from_output "$local_oid" "$diff_output"
}

resolve_new_ref_baseline() {
  local local_ref="$1"
  local local_oid="$2"
  local local_branch=""
  local upstream_ref=""
  local baseline_oid=""

  if [[ "$local_ref" == refs/heads/* ]]; then
    local_branch="${local_ref#refs/heads/}"
    if upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name "${local_branch}@{upstream}" 2> /dev/null)" && [[ -n "$upstream_ref" ]]; then
      if baseline_oid="$(git merge-base "$local_oid" "$upstream_ref" 2> /dev/null)" && [[ -n "$baseline_oid" ]]; then
        printf '%s\n' "$baseline_oid"
        return 0
      fi
    fi
  fi

  if git rev-parse --verify --quiet "origin/HEAD^{commit}" > /dev/null; then
    if baseline_oid="$(git merge-base "$local_oid" "origin/HEAD" 2> /dev/null)" && [[ -n "$baseline_oid" ]]; then
      printf '%s\n' "$baseline_oid"
      return 0
    fi
  fi

  if git rev-parse --verify --quiet "${local_oid}^" > /dev/null; then
    printf '%s\n' "${local_oid}^"
    return 0
  fi

  return 1
}

append_tracked_files_fallback() {
  local local_oid="$1"
  local tracked_output
  local tracked_stderr
  local tracked_stderr_path
  local tracked_exit

  if ! tracked_stderr_path="$(mktemp 2> /dev/null)"; then
    tracked_stderr_path="/tmp/wallstop-prepush-ls-files.$$.$RANDOM.err"
  fi
  set +e
  tracked_output="$(git ls-tree -r --name-only "$local_oid" 2> "$tracked_stderr_path")"
  tracked_exit=$?
  tracked_stderr=""
  if [[ -f "$tracked_stderr_path" ]]; then
    tracked_stderr="$(< "$tracked_stderr_path")"
  fi
  rm -f "$tracked_stderr_path" > /dev/null 2>&1 || true
  set -e

  if [[ $tracked_exit -ne 0 ]]; then
    local tracked_diagnostic_output="$tracked_output"
    if [[ -n "$tracked_stderr" ]]; then
      if [[ -n "$tracked_diagnostic_output" ]]; then
        tracked_diagnostic_output="${tracked_diagnostic_output}"$'\n'"${tracked_stderr}"
      else
        tracked_diagnostic_output="$tracked_stderr"
      fi
    fi
    emit_diagnostic "E_PREPUSH_CHANGED_FILE_FALLBACK_FAILED: failed to list pushed commit tree for missing-baseline fallback (exitCode=${tracked_exit}). Git output: ${tracked_diagnostic_output}"
    return "$tracked_exit"
  fi

  append_changed_files_from_output "$local_oid" "$tracked_output"
}

dedupe_changed_files() {
  local sorted_pairs=""
  local changed_file=""
  local changed_oid=""
  local index

  if [[ ${#resolved_changed_files[@]} -eq 0 ]]; then
    return 0
  fi

  sorted_pairs="$(
    for index in "${!resolved_changed_files[@]}"; do
      printf '%s\t%s\n' "${resolved_changed_file_oids[$index]}" "${resolved_changed_files[$index]}"
    done | LC_ALL=C sort -u
  )"
  resolved_changed_files=()
  resolved_changed_file_oids=()
  while IFS=$'\t' read -r changed_oid changed_file; do
    if [[ -n "$changed_file" && -n "$changed_oid" ]]; then
      resolved_changed_files+=("$changed_file")
      resolved_changed_file_oids+=("$changed_oid")
    fi
  done <<< "$sorted_pairs"
}

write_changed_file_list() {
  if [[ -z "$changed_file_list_path" ]]; then
    changed_file_list_path="$(mktemp 2> /dev/null || true)"
    if [[ -z "$changed_file_list_path" ]]; then
      changed_file_list_path="/tmp/wallstop-prepush-files.$$.$RANDOM.list"
    fi
  fi

  printf '%s\n' "${resolved_changed_files[@]}" > "$changed_file_list_path"
}

ensure_prepush_full_suite_can_use_worktree() {
  local file
  local local_oid
  local index
  local pushed_hash
  local worktree_hash
  local index_hash

  if [[ "$saw_non_head_push_ref" -ne 0 ]]; then
    emit_diagnostic "E_PREPUSH_FULL_NON_HEAD_REF: recovery-backed pre-push validation reads working-tree files and refuses to validate pushed commits that differ from HEAD. The default fast gate validates supported pushed blobs directly."
    return 1
  fi

  for index in "${!resolved_changed_files[@]}"; do
    file="${resolved_changed_files[$index]}"
    local_oid="${resolved_changed_file_oids[$index]}"
    [[ -n "$file" ]] || continue
    [[ -n "$local_oid" ]] || continue

    if ! git cat-file -e "${local_oid}:${file}" > /dev/null 2>&1; then
      continue
    fi

    if [[ ! -f "$file" ]]; then
      emit_diagnostic "E_PREPUSH_FULL_WORKTREE_DRIFT: recovery-backed pre-push validation reads working-tree files and refuses to validate a missing or non-file worktree target. Commit, stash, or restore this file before running WALLSTOP_PREPUSH_FULL_SUITE=1. file=${file}"
      return 1
    fi

    if ! pushed_hash="$(git rev-parse "${local_oid}:${file}" 2> /dev/null)"; then
      emit_diagnostic "E_PREPUSH_FULL_BLOB_COMPARE_FAILED: failed to resolve pushed blob for full-suite worktree guard. file=${file} localOid=${local_oid}"
      return 1
    fi

    if ! worktree_hash="$(git hash-object -- "$file" 2> /dev/null)"; then
      emit_diagnostic "E_PREPUSH_FULL_WORKTREE_HASH_FAILED: failed to hash worktree target for full-suite guard. file=${file}"
      return 1
    fi

    if [[ "$worktree_hash" != "$pushed_hash" ]]; then
      emit_diagnostic "E_PREPUSH_FULL_WORKTREE_DRIFT: recovery-backed pre-push validation reads working-tree files and refuses to validate content that differs from the pushed blob. Commit, stash, or restore this file before running WALLSTOP_PREPUSH_FULL_SUITE=1. file=${file}"
      return 1
    fi

    if ! index_hash="$(git rev-parse ":${file}" 2> /dev/null)"; then
      emit_diagnostic "E_PREPUSH_FULL_INDEX_DRIFT: recovery-backed pre-push validation reads working-tree files and refuses to validate a target missing from the git index. Commit, stash, or restore this file before running WALLSTOP_PREPUSH_FULL_SUITE=1. file=${file}"
      return 1
    fi

    if [[ "$index_hash" != "$pushed_hash" ]]; then
      emit_diagnostic "E_PREPUSH_FULL_INDEX_DRIFT: recovery-backed pre-push validation reads working-tree files and refuses to validate index content that differs from the pushed blob. Commit, stash, or restore this file before running WALLSTOP_PREPUSH_FULL_SUITE=1. file=${file}"
      return 1
    fi
  done

  return 0
}

resolve_pre_push_changed_files() {
  local local_ref=""
  local local_oid=""
  local remote_ref=""
  local remote_oid=""
  local baseline_oid=""
  local discovery_status=0

  while read -r local_ref local_oid remote_ref remote_oid; do
    if [[ -z "${local_ref}${local_oid}${remote_ref}${remote_oid}" ]]; then
      continue
    fi

    saw_pre_push_ref_update=1

    if [[ "$local_oid" == "$zero_oid" ]]; then
      emit_diagnostic "pre-push changed-file validation: skipping delete push for ${remote_ref}."
      continue
    fi

    if ! git merge-base --is-ancestor "$local_oid" HEAD > /dev/null 2>&1 || ! git merge-base --is-ancestor HEAD "$local_oid" > /dev/null 2>&1; then
      saw_non_head_push_ref=1
    fi

    if [[ "$remote_oid" != "$zero_oid" ]]; then
      set +e
      append_diff_changed_files "$remote_oid" "$local_oid"
      discovery_status=$?
      set -e
      if [[ $discovery_status -ne 0 ]]; then
        return "$discovery_status"
      fi
      continue
    fi

    if baseline_oid="$(resolve_new_ref_baseline "$local_ref" "$local_oid")"; then
      set +e
      append_diff_changed_files "$baseline_oid" "$local_oid"
      discovery_status=$?
      set -e
      if [[ $discovery_status -ne 0 ]]; then
        return "$discovery_status"
      fi
      continue
    fi

    emit_diagnostic "W_PREPUSH_CHANGED_FILE_BASELINE_MISSING: no baseline found for ${local_ref}; falling back to tracked file list."
    set +e
    append_tracked_files_fallback "$local_oid"
    discovery_status=$?
    set -e
    if [[ $discovery_status -ne 0 ]]; then
      return "$discovery_status"
    fi
  done

  if [[ $saw_pre_push_ref_update -eq 0 ]]; then
    emit_diagnostic "pre-push changed-file validation: no ref updates received; skipping validation."
  fi

  dedupe_changed_files
  return 0
}

run_legacy_validation() {
  if [[ ${#resolved_changed_files[@]} -eq 0 ]]; then
    emit_diagnostic "pre-push changed-file validation: no changed files to validate."
    return 0
  fi

  if command -v pwsh > /dev/null 2>&1; then
    local remaining_seconds
    local target_file_list_path

    write_changed_file_list
    target_file_list_path="$changed_file_list_path"
    if ! remaining_seconds="$(remaining_timeout_seconds "legacy pre-push PowerShell validation")"; then
      return 124
    fi

    set +e
    run_with_timeout "$remaining_seconds" "legacy pre-push PowerShell validation" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Run-PreCommitValidation.ps1" -IncludePreCommitOwnedChecks -TargetFileListPath "$target_file_list_path"
    local legacy_validation_exit=$?
    set -e
    return $legacy_validation_exit
  fi

  emit_diagnostic "pre-commit is unavailable and pwsh was not found; cannot run legacy PowerShell quality gates."
  emit_diagnostic "Install pre-commit with:"
  print_precommit_bootstrap_guidance
  emit_diagnostic "Install PowerShell from: https://learn.microsoft.com/powershell/scripting/install/installing-powershell"
  exit 1
}

set +e
resolve_pre_push_changed_files
changed_file_discovery_exit=$?
set -e

if [[ $changed_file_discovery_exit -ne 0 ]]; then
  emit_runtime_budget_warning "pre-push changed-file discovery failed" "$((SECONDS - hook_start_seconds))"
  exit "$changed_file_discovery_exit"
fi

if [[ $saw_pre_push_ref_update -eq 0 ]]; then
  emit_runtime_budget_warning "pre-push no ref updates" "$((SECONDS - hook_start_seconds))"
  exit 0
fi

if [[ ${#resolved_changed_files[@]} -eq 0 ]]; then
  emit_diagnostic "pre-push changed-file validation: no changed files to validate."
  emit_runtime_budget_warning "pre-push no changed files" "$((SECONDS - hook_start_seconds))"
  exit 0
fi

if ! is_truthy "${WALLSTOP_PREPUSH_FULL_SUITE:-0}"; then
  run_fast_prepush_gate
  fast_gate_exit=$?
  if [[ $fast_gate_exit -eq 0 ]]; then
    emit_runtime_budget_warning "pre-push fast gate" "$((SECONDS - hook_start_seconds))"
    exit 0
  fi

  exit $fast_gate_exit
fi

if ! ensure_prepush_full_suite_can_use_worktree; then
  emit_runtime_budget_warning "pre-push full-suite worktree guard" "$((SECONDS - hook_start_seconds))"
  exit 1
fi

if command -v pwsh > /dev/null 2>&1; then
  write_changed_file_list
  target_file_list_path="$changed_file_list_path"
  if remaining_seconds="$(remaining_timeout_seconds "pre-push changed-file pre-commit validation")"; then
    inner_timeout_seconds=$((remaining_seconds - prepush_recovery_shutdown_buffer_seconds))
    required_remaining_seconds=$((prepush_recovery_inner_timeout_seconds + prepush_recovery_shutdown_buffer_seconds))
    if [[ "$inner_timeout_seconds" -lt "$prepush_recovery_inner_timeout_seconds" ]]; then
      emit_recovery_budget_diagnostic "pre-push changed-file pre-commit validation" "$remaining_seconds" "$required_remaining_seconds" "$inner_timeout_seconds"
      exit 124
    fi

    set +e
    run_with_timeout "$remaining_seconds" "pre-push changed-file pre-commit validation" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Quality/Invoke-PreCommitWithRecovery.ps1" -HookStage pre-push -TimeoutSeconds "$inner_timeout_seconds" -FileListPath "$target_file_list_path"
    recovery_exit=$?
    set -e
    if [[ $recovery_exit -eq 0 ]]; then
      exit 0
    fi

    if [[ $recovery_exit -eq 125 ]]; then
      emit_diagnostic "W_PREPUSH_RECOVERY_DEGRADED: the pinned pre-commit CLI could not be prepared (missing CLI, pinned-version mismatch, or resolution failure - see the E_VALIDATION_PRECOMMIT_* diagnostic above); falling back to legacy PowerShell checks. CI still runs the pinned pre-commit CLI."
      emit_diagnostic "Recommended bootstrap:"
      print_precommit_bootstrap_guidance
      emit_diagnostic "      # persist PATH in ~/.bashrc or ~/.zshrc for future shells"
      emit_diagnostic "  pre-commit install --hook-type pre-commit --hook-type pre-push"
      emit_diagnostic "Major changes should close with the full validation command documented in .llm/validation-workflow.md."
      run_legacy_validation
      exit $?
    fi

    exit $recovery_exit
  fi

  exit 124
fi

if command -v pre-commit > /dev/null 2>&1; then
  if remaining_seconds="$(remaining_timeout_seconds "pre-commit hook-stage pre-push changed files")"; then
    set +e
    run_with_timeout "$remaining_seconds" "pre-commit hook-stage pre-push changed files" pre-commit run --hook-stage pre-push --files "${resolved_changed_files[@]}" --show-diff-on-failure --color always
    precommit_hook_exit=$?
    set -e
    exit $precommit_hook_exit
  fi

  exit 124
fi

emit_diagnostic "pre-commit is not installed; falling back to legacy PowerShell checks."
emit_diagnostic "Recommended bootstrap:"
print_precommit_bootstrap_guidance
emit_diagnostic "      # persist PATH in ~/.bashrc or ~/.zshrc for future shells"
emit_diagnostic "  pre-commit install --hook-type pre-commit --hook-type pre-push"
emit_diagnostic "Major changes should close with the full validation command documented in .llm/validation-workflow.md."
run_legacy_validation
exit $?
