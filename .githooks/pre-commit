#!/usr/bin/env bash
set -euo pipefail

if ! command -v git > /dev/null 2>&1; then
  echo "E_PRECOMMIT_HOOK_GIT_NOT_AVAILABLE: git is required for hook execution but was not found on PATH."
  exit 1
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

precommit_timeout_seconds="${WALLSTOP_PRECOMMIT_TIMEOUT_SECONDS:-600}"
precommit_recovery_shutdown_buffer_seconds=15
minimum_precommit_timeout_seconds=$((30 + precommit_recovery_shutdown_buffer_seconds))
hook_start_seconds="$SECONDS"

validate_timeout_seconds() {
  local timeout_value="$1"
  local env_name="$2"

  if [[ ! "$timeout_value" =~ ^[0-9]+$ ]] || [[ "$timeout_value" -lt "$minimum_precommit_timeout_seconds" ]]; then
    echo "E_HOOK_TIMEOUT_CONFIG: ${env_name} must be an integer >= ${minimum_precommit_timeout_seconds} seconds (30s inner recovery timeout plus ${precommit_recovery_shutdown_buffer_seconds}s shutdown buffer; received '${timeout_value}')."
    exit 2
  fi
}

resolve_timeout_command() {
  if command -v timeout > /dev/null 2>&1; then
    printf '%s\n' "timeout"
    return 0
  fi

  if command -v gtimeout > /dev/null 2>&1; then
    printf '%s\n' "gtimeout"
    return 0
  fi

  return 1
}

run_with_timeout() {
  local timeout_seconds="$1"
  shift
  local label="$1"
  shift
  local phase_start_seconds=$SECONDS

  local timeout_command
  if timeout_command="$(resolve_timeout_command)"; then
    set +e
    "$timeout_command" --foreground "${timeout_seconds}s" "$@"
    local command_exit=$?
    set -e

    if [[ $command_exit -eq 124 || $command_exit -eq 137 ]]; then
      echo "E_HOOK_TIMEOUT: ${label} exceeded ${timeout_seconds}s. Override with WALLSTOP_PRECOMMIT_TIMEOUT_SECONDS."
    fi

    local elapsed_seconds=$((SECONDS - phase_start_seconds))
    if [[ $elapsed_seconds -gt 1 ]]; then
      echo "W_HOOK_RUNTIME_BUDGET: ${label} took ${elapsed_seconds}s (target <= 1s fast-path)."
    fi

    return $command_exit
  fi

  echo "W_HOOK_TIMEOUT_UNAVAILABLE: timeout/gtimeout not found; using shell watchdog timeout for '${label}'."

  local timeout_flag_file
  timeout_flag_file="$(mktemp 2> /dev/null || true)"
  if [[ -z "$timeout_flag_file" ]]; then
    timeout_flag_file="/tmp/wallstop-hook-timeout.$$.$RANDOM.flag"
  fi
  rm -f "$timeout_flag_file"

  set +e
  "$@" &
  local command_pid=$!
  (
    sleep "$timeout_seconds"
    if kill -0 "$command_pid" > /dev/null 2>&1; then
      : > "$timeout_flag_file"
      kill -TERM "$command_pid" > /dev/null 2>&1 || true
      sleep 2
      if kill -0 "$command_pid" > /dev/null 2>&1; then
        kill -KILL "$command_pid" > /dev/null 2>&1 || true
      fi
    fi
  ) &
  local watchdog_pid=$!

  wait "$command_pid"
  local fallback_exit=$?
  kill "$watchdog_pid" > /dev/null 2>&1 || true
  wait "$watchdog_pid" > /dev/null 2>&1 || true
  set -e

  if [[ -f "$timeout_flag_file" ]]; then
    rm -f "$timeout_flag_file"
    echo "E_HOOK_TIMEOUT: ${label} exceeded ${timeout_seconds}s. Override with WALLSTOP_PRECOMMIT_TIMEOUT_SECONDS."
    local elapsed_seconds=$((SECONDS - phase_start_seconds))
    if [[ $elapsed_seconds -gt 1 ]]; then
      echo "W_HOOK_RUNTIME_BUDGET: ${label} took ${elapsed_seconds}s (target <= 1s fast-path)."
    fi
    return 124
  fi

  rm -f "$timeout_flag_file"
  local elapsed_seconds=$((SECONDS - phase_start_seconds))
  if [[ $elapsed_seconds -gt 1 ]]; then
    echo "W_HOOK_RUNTIME_BUDGET: ${label} took ${elapsed_seconds}s (target <= 1s fast-path)."
  fi
  return $fallback_exit
}

remaining_timeout_seconds() {
  local phase_label="$1"
  local elapsed_seconds=$((SECONDS - hook_start_seconds))
  local remaining_seconds=$((precommit_timeout_seconds - elapsed_seconds))

  if [[ "$remaining_seconds" -lt 1 ]]; then
    echo "E_HOOK_TIMEOUT: ${phase_label} exceeded total hook budget of ${precommit_timeout_seconds}s. Override with WALLSTOP_PRECOMMIT_TIMEOUT_SECONDS." >&2
    return 1
  fi

  printf '%s\n' "$remaining_seconds"
}

validate_timeout_seconds "$precommit_timeout_seconds" "WALLSTOP_PRECOMMIT_TIMEOUT_SECONDS"

required_precommit_version() {
  local requirements_path="${repo_root}/requirements.txt"
  local version=""

  if [[ -f "$requirements_path" ]]; then
    version="$(awk -F'==' '/^[[:space:]]*pre-commit==/ { gsub(/[[:space:]].*$/, "", $2); print $2; exit }' "$requirements_path")"
  fi

  if [[ -n "$version" ]]; then
    printf '%s\n' "$version"
  else
    printf '%s\n' "<pinned-version-from-requirements.txt>"
  fi
}

print_precommit_bootstrap_guidance() {
  local pinned_version
  pinned_version="$(required_precommit_version)"

  echo "  pipx install pre-commit==${pinned_version}"
  echo "    or via venv:"
  echo "      python3 -m venv ~/.local/venvs/pre-commit"
  echo "      ~/.local/venvs/pre-commit/bin/pip install --requirement requirements.txt"
  echo "      mkdir -p ~/.local/bin"
  echo "      ln -sf ~/.local/venvs/pre-commit/bin/pre-commit ~/.local/bin/pre-commit"
  echo "      export PATH=\"\$HOME/.local/bin:\$PATH\""
}

run_legacy_validation() {
  if command -v pwsh > /dev/null 2>&1; then
    local remaining_seconds
    if ! remaining_seconds="$(remaining_timeout_seconds "legacy pre-commit PowerShell validation")"; then
      return 124
    fi

    run_with_timeout "$remaining_seconds" "legacy pre-commit PowerShell validation" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Run-PreCommitValidation.ps1"
    return $?
  fi

  echo "pre-commit is unavailable and pwsh was not found; cannot run legacy PowerShell quality gates."
  echo "Install pre-commit with:"
  print_precommit_bootstrap_guidance
  echo "Install PowerShell from: https://learn.microsoft.com/powershell/scripting/install/installing-powershell"
  exit 1
}

has_staged_windows_language_targets() {
  local staged_files
  if ! staged_files="$(git -C "$repo_root" diff --cached --name-only --diff-filter=ACMR -- 2> /dev/null)"; then
    echo "W_PRECOMMIT_AUTOREPAIR_PREFILTER_FAILED: unable to read staged files for auto-repair prefilter; running pwsh auto-repair fallback."
    return 0
  fi

  if [[ -z "$staged_files" ]]; then
    return 1
  fi

  if printf '%s\n' "$staged_files" | grep -Ei '^(Scripts/AutoHotKey/.+\.ahk|Config/\.config/.+\.ahk|Scripts/.+\.bat)$' > /dev/null 2>&1; then
    return 0
  fi

  return 1
}

run_safe_autorepair() {
  if command -v pwsh > /dev/null 2>&1; then
    if ! has_staged_windows_language_targets; then
      return 0
    fi

    local remaining_seconds
    if ! remaining_seconds="$(remaining_timeout_seconds "pre-commit safe auto-repair")"; then
      return 124
    fi

    run_with_timeout "$remaining_seconds" "pre-commit safe auto-repair" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Quality/Invoke-PreCommitAutoRepair.ps1"
    return $?
  fi

  return 0
}

if command -v pre-commit > /dev/null 2>&1; then
  if command -v pwsh > /dev/null 2>&1; then
    if run_safe_autorepair; then
      :
    else
      safe_autorepair_exit=$?
      exit $safe_autorepair_exit
    fi

    if remaining_seconds="$(remaining_timeout_seconds "pre-commit hook-stage pre-commit")"; then
      inner_timeout_seconds=$((remaining_seconds - precommit_recovery_shutdown_buffer_seconds))
      if [[ "$inner_timeout_seconds" -lt 30 ]]; then
        echo "E_HOOK_TIMEOUT: pre-commit hook-stage pre-commit has ${remaining_seconds}s remaining, below minimum safe inner timeout (30s) plus shutdown buffer (${precommit_recovery_shutdown_buffer_seconds}s)."
        exit 124
      fi

      run_with_timeout "$remaining_seconds" "pre-commit hook-stage pre-commit" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Quality/Invoke-PreCommitWithRecovery.ps1" -HookStage pre-commit -TimeoutSeconds "$inner_timeout_seconds"
      exit $?
    fi

    exit 124
  fi

  if remaining_seconds="$(remaining_timeout_seconds "pre-commit hook-stage pre-commit")"; then
    run_with_timeout "$remaining_seconds" "pre-commit hook-stage pre-commit" pre-commit run --hook-stage pre-commit --show-diff-on-failure --color always
    exit $?
  fi

  exit 124
fi

echo "pre-commit is not installed; falling back to legacy PowerShell checks."
echo "Recommended bootstrap:"
print_precommit_bootstrap_guidance
echo "      # persist PATH in ~/.bashrc or ~/.zshrc for future shells"
echo "  pre-commit install --hook-type pre-commit --hook-type pre-push"
echo "Major changes should close with: pwsh -NoLogo -NoProfile -File Scripts/Utils/Quality/Invoke-FullValidation.ps1"
run_legacy_validation
exit $?
