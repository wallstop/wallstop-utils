#!/usr/bin/env bash
set -euo pipefail

emit_diagnostic() {
  printf '%s\n' "$*" >&2
}

if ! command -v git > /dev/null 2>&1; then
  emit_diagnostic "E_PRECOMMIT_HOOK_GIT_NOT_AVAILABLE: git is required for hook execution but was not found on PATH."
  exit 1
fi

hook_start_seconds="$SECONDS"

if ! repo_root_stderr_path="$(mktemp 2> /dev/null)"; then
  repo_root_stderr_path="/tmp/wallstop-precommit-repo-root.$$.$RANDOM.err"
fi
set +e
repo_root="$(git rev-parse --show-toplevel 2> "$repo_root_stderr_path")"
repo_root_exit=$?
repo_root_stderr=""
if [[ -f "$repo_root_stderr_path" ]]; then
  repo_root_stderr="$(< "$repo_root_stderr_path")"
fi
rm -f "$repo_root_stderr_path" > /dev/null 2>&1 || true
set -e
if [[ $repo_root_exit -ne 0 || -z "$repo_root" ]]; then
  if [[ $repo_root_exit -eq 0 ]]; then
    repo_root_exit=1
  fi
  repo_root_output="$repo_root"
  if [[ -n "$repo_root_stderr" ]]; then
    if [[ -n "$repo_root_output" ]]; then
      repo_root_output="${repo_root_output}"$'\n'"${repo_root_stderr}"
    else
      repo_root_output="$repo_root_stderr"
    fi
  fi
  git_command="$(command -v git 2> /dev/null || printf '<unresolved>')"
  working_directory="$(pwd 2> /dev/null || printf '<unresolved>')"
  emit_diagnostic "E_PRECOMMIT_REPO_ROOT_UNAVAILABLE: failed to resolve repository root (exitCode=${repo_root_exit}; workingDirectory=${working_directory}; gitCommand=${git_command}). Git output: ${repo_root_output}"
  exit "$repo_root_exit"
fi
cd "$repo_root"

precommit_home="${repo_root}/.tools/precommit-cli/pre-commit-home"
if mkdir -p "$precommit_home" > /dev/null 2>&1; then
  export PRE_COMMIT_HOME="$precommit_home"
else
  emit_diagnostic "W_PRECOMMIT_HOME_UNAVAILABLE: unable to create managed PRE_COMMIT_HOME at '${precommit_home}'; pre-commit will use its host default cache."
fi

fast_validation_root_path=""
trap 'if [[ -n "$fast_validation_root_path" ]]; then rm -rf "$fast_validation_root_path"; fi' EXIT

hook_timeout_helpers_path="${repo_root}/Scripts/Utils/Common/HookTimeout.sh"
if [[ ! -f "$hook_timeout_helpers_path" ]]; then
  emit_diagnostic "E_HOOK_TIMEOUT_HELPER_MISSING: timeout helper file not found at '$hook_timeout_helpers_path'."
  exit 1
fi

# shellcheck source=Scripts/Utils/Common/HookTimeout.sh
. "$hook_timeout_helpers_path"

fast_tool_resolver_loaded=0

precommit_timeout_seconds="${WALLSTOP_PRECOMMIT_TIMEOUT_SECONDS:-600}"
precommit_recovery_inner_timeout_seconds=30
precommit_recovery_shutdown_buffer_seconds=15
precommit_recovery_setup_slack_seconds=15
minimum_precommit_timeout_seconds=$((precommit_recovery_inner_timeout_seconds + precommit_recovery_shutdown_buffer_seconds + precommit_recovery_setup_slack_seconds))

validate_timeout_seconds() {
  local timeout_value="$1"
  local env_name="$2"

  if [[ ! "$timeout_value" =~ ^[0-9]+$ ]] || [[ "$timeout_value" -lt "$minimum_precommit_timeout_seconds" ]]; then
    emit_diagnostic "E_HOOK_TIMEOUT_CONFIG: ${env_name} must be an integer >= ${minimum_precommit_timeout_seconds} seconds (${precommit_recovery_inner_timeout_seconds}s inner recovery timeout plus ${precommit_recovery_shutdown_buffer_seconds}s shutdown buffer plus ${precommit_recovery_setup_slack_seconds}s setup slack; received '${timeout_value}')."
    exit 2
  fi
}

resolve_timeout_command() {
  wallstop_resolve_timeout_command
}

describe_timeout_provider() {
  local timeout_command
  if timeout_command="$(resolve_timeout_command)"; then
    printf '%s\n' "$timeout_command"
    return 0
  fi

  printf '%s\n' "shell-watchdog"
}

runtime_budget_seconds() {
  local label="$1"
  case "$label" in
    "pre-commit hook-stage pre-commit" | "legacy pre-commit PowerShell validation" | "pre-commit safe auto-repair")
      printf '%s\n' "${WALLSTOP_PRECOMMIT_ACTIVE_RUNTIME_BUDGET_SECONDS:-30}"
      ;;
    "pre-commit fast gate" | "pre-commit fast actionlint" | "pre-commit fast actionlint bootstrap")
      printf '%s\n' "${WALLSTOP_PRECOMMIT_FAST_RUNTIME_BUDGET_SECONDS:-1}"
      ;;
    *)
      printf '%s\n' "${WALLSTOP_PRECOMMIT_NOOP_RUNTIME_BUDGET_SECONDS:-1}"
      ;;
  esac
}

emit_runtime_budget_warning() {
  local label="$1"
  local elapsed_seconds="$2"
  local budget_seconds
  budget_seconds="$(runtime_budget_seconds "$label")"

  if [[ ! "$budget_seconds" =~ ^[0-9]+$ ]] || [[ "$budget_seconds" -lt 1 ]]; then
    budget_seconds=1
  fi

  if [[ $elapsed_seconds -gt $budget_seconds ]]; then
    emit_diagnostic "W_HOOK_RUNTIME_BUDGET: ${label} took ${elapsed_seconds}s (budget <= ${budget_seconds}s; no-op fast-path target <= 1s)."
  fi
}

emit_recovery_budget_diagnostic() {
  local phase_label="$1"
  local remaining_seconds="$2"
  local required_remaining_seconds="$3"
  local inner_timeout_seconds="$4"
  local elapsed_seconds=$((SECONDS - hook_start_seconds))
  local timeout_provider
  timeout_provider="$(describe_timeout_provider)"

  emit_diagnostic "E_HOOK_TIMEOUT: ${phase_label} has ${remaining_seconds}s remaining, below required recovery budget. configuredTimeoutSeconds=${precommit_timeout_seconds}; elapsedSetupSeconds=${elapsed_seconds}; remainingSeconds=${remaining_seconds}; requiredRemainingSeconds=${required_remaining_seconds}; innerTimeoutSeconds=${inner_timeout_seconds}; minimumInnerTimeoutSeconds=${precommit_recovery_inner_timeout_seconds}; shutdownBufferSeconds=${precommit_recovery_shutdown_buffer_seconds}; setupSlackSeconds=${precommit_recovery_setup_slack_seconds}; timeoutProvider=${timeout_provider}."
}

run_with_timeout() {
  local timeout_seconds="$1"
  shift
  local label="$1"
  shift
  local phase_start_seconds=$SECONDS
  local caller_errexit_enabled=0
  case "$-" in
    *e*) caller_errexit_enabled=1 ;;
  esac

  local timeout_command
  if timeout_command="$(resolve_timeout_command)"; then
    set +e
    "$timeout_command" -k 2s "${timeout_seconds}s" "$@"
    local command_exit=$?
    if [[ $caller_errexit_enabled -eq 1 ]]; then
      set -e
    else
      set +e
    fi

    if [[ $command_exit -eq 124 || $command_exit -eq 137 ]]; then
      emit_diagnostic "E_HOOK_TIMEOUT: ${label} exceeded ${timeout_seconds}s. Override with WALLSTOP_PRECOMMIT_TIMEOUT_SECONDS."
    fi

    local elapsed_seconds=$((SECONDS - phase_start_seconds))
    emit_runtime_budget_warning "$label" "$elapsed_seconds"

    return $command_exit
  fi

  emit_diagnostic "W_HOOK_TIMEOUT_UNAVAILABLE: timeout/gtimeout not found; using shell watchdog timeout for '${label}'."

  local timeout_flag_file
  timeout_flag_file="$(mktemp 2> /dev/null || true)"
  if [[ -z "$timeout_flag_file" ]]; then
    timeout_flag_file="/tmp/wallstop-hook-timeout.$$.$RANDOM.flag"
  fi
  rm -f "$timeout_flag_file"

  set +e
  WALLSTOP_TIMEOUT_COMMAND_PID=""
  WALLSTOP_TIMEOUT_COMMAND_PROCESS_GROUP_MODE=""
  wallstop_start_timeout_command "$label" "$@"
  local command_pid="$WALLSTOP_TIMEOUT_COMMAND_PID"
  local command_process_group_mode="$WALLSTOP_TIMEOUT_COMMAND_PROCESS_GROUP_MODE"
  (
    sleep "$timeout_seconds"
    if wallstop_is_timeout_command_alive "$command_pid" "$command_process_group_mode"; then
      : > "$timeout_flag_file"
      wallstop_terminate_timeout_command "$command_pid" "$command_process_group_mode"
    fi
  ) &
  local watchdog_pid=$!

  wait "$command_pid"
  local fallback_exit=$?
  kill "$watchdog_pid" > /dev/null 2>&1 || true
  wait "$watchdog_pid" > /dev/null 2>&1 || true
  wallstop_cleanup_timeout_command_processes "$command_pid" "$command_process_group_mode" "$label"
  if [[ $caller_errexit_enabled -eq 1 ]]; then
    set -e
  else
    set +e
  fi

  if [[ -f "$timeout_flag_file" ]]; then
    rm -f "$timeout_flag_file"
    emit_diagnostic "E_HOOK_TIMEOUT: ${label} exceeded ${timeout_seconds}s. Override with WALLSTOP_PRECOMMIT_TIMEOUT_SECONDS."
    local elapsed_seconds=$((SECONDS - phase_start_seconds))
    emit_runtime_budget_warning "$label" "$elapsed_seconds"
    return 124
  fi

  rm -f "$timeout_flag_file"
  local elapsed_seconds=$((SECONDS - phase_start_seconds))
  emit_runtime_budget_warning "$label" "$elapsed_seconds"
  return $fallback_exit
}

remaining_timeout_seconds() {
  local phase_label="$1"
  local elapsed_seconds=$((SECONDS - hook_start_seconds))
  local remaining_seconds=$((precommit_timeout_seconds - elapsed_seconds))

  if [[ "$remaining_seconds" -lt 1 ]]; then
    emit_recovery_budget_diagnostic "$phase_label" "$remaining_seconds" 1 0
    return 1
  fi

  printf '%s\n' "$remaining_seconds"
}

validate_timeout_seconds "$precommit_timeout_seconds" "WALLSTOP_PRECOMMIT_TIMEOUT_SECONDS"

required_precommit_version() {
  local requirements_path="${repo_root}/requirements.txt"
  local version=""

  if [[ -f "$requirements_path" ]]; then
    version="$(awk -F'==' '/^[[:space:]]*pre-commit==/ { gsub(/[[:space:]].*$/, "", $2); print $2; exit }' "$requirements_path")"
  fi

  if [[ -n "$version" ]]; then
    printf '%s\n' "$version"
  else
    printf '%s\n' "<pinned-version-from-requirements.txt>"
  fi
}

print_precommit_bootstrap_guidance() {
  local pinned_version
  pinned_version="$(required_precommit_version)"

  emit_diagnostic "  pipx install pre-commit==${pinned_version}"
  emit_diagnostic "    or via venv:"
  emit_diagnostic "      python3 -m venv ~/.local/venvs/pre-commit"
  emit_diagnostic "      ~/.local/venvs/pre-commit/bin/pip install --requirement requirements.txt"
  emit_diagnostic "      mkdir -p ~/.local/bin"
  emit_diagnostic "      ln -sf ~/.local/venvs/pre-commit/bin/pre-commit ~/.local/bin/pre-commit"
  emit_diagnostic "      export PATH=\"\$HOME/.local/bin:\$PATH\""
}

run_legacy_validation() {
  if command -v pwsh > /dev/null 2>&1; then
    local remaining_seconds
    if ! remaining_seconds="$(remaining_timeout_seconds "legacy pre-commit PowerShell validation")"; then
      return 124
    fi

    run_with_timeout "$remaining_seconds" "legacy pre-commit PowerShell validation" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Run-PreCommitValidation.ps1" -IncludePreCommitOwnedChecks -AllowPreCommitOwnedFixes
    return $?
  fi

  emit_diagnostic "pre-commit is unavailable and pwsh was not found; cannot run legacy PowerShell quality gates."
  emit_diagnostic "Install pre-commit with:"
  print_precommit_bootstrap_guidance
  emit_diagnostic "Install PowerShell from: https://learn.microsoft.com/powershell/scripting/install/installing-powershell"
  exit 1
}

is_truthy() {
  case "${1:-}" in
    1 | true | TRUE | yes | YES | on | ON)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

get_staged_precommit_fast_files() {
  if ! git -C "$repo_root" diff --cached --name-only --diff-filter=ACMR -- \
    "Scripts/*.sh" \
    ".devcontainer/*.sh" \
    ".githooks/pre-commit" \
    ".githooks/pre-push" \
    ".github/workflows/*.yml" \
    ".github/workflows/*.yaml" \
    "Scripts/AutoHotKey/*.ahk" \
    "Config/.config/*.ahk" \
    "Scripts/*.bat" 2> /dev/null; then
    emit_diagnostic "W_PRECOMMIT_FAST_STAGED_DISCOVERY_FAILED: unable to read staged files for fast hook gate; running recovery-backed validation."
    return 1
  fi
}

get_staged_precommit_files() {
  if ! git -C "$repo_root" diff --cached --name-only --diff-filter=ACMRD -- 2> /dev/null; then
    emit_diagnostic "W_PRECOMMIT_STAGED_DISCOVERY_FAILED: unable to read staged files for hook gate; running recovery-backed validation."
    return 1
  fi
}

run_precommit_fast_diff_check() {
  if is_truthy "${WALLSTOP_PRECOMMIT_FAST_DIFF_CHECK:-0}"; then
    if ! git -C "$repo_root" diff --cached --check --; then
      return 1
    fi
  fi
}

has_staged_windows_language_targets() {
  local staged_files="$1"

  if [[ -z "$staged_files" ]]; then
    return 1
  fi

  if printf '%s\n' "$staged_files" | grep -Ei '^(Scripts/AutoHotKey/.+\.ahk|Config/\.config/.+\.ahk|Scripts/.+\.bat)$' > /dev/null 2>&1; then
    return 0
  fi

  return 1
}

load_fast_tool_resolver() {
  if [[ "$fast_tool_resolver_loaded" -eq 1 ]]; then
    return 0
  fi

  local fast_tool_resolver_path="${repo_root}/Scripts/Utils/Common/HookFastToolResolver.sh"
  if [[ ! -f "$fast_tool_resolver_path" ]]; then
    emit_diagnostic "E_PRECOMMIT_FAST_TOOL_RESOLVER_MISSING: fast tool resolver file not found at '$fast_tool_resolver_path'."
    return 1
  fi

  # shellcheck source=Scripts/Utils/Common/HookFastToolResolver.sh
  . "$fast_tool_resolver_path"
  fast_tool_resolver_loaded=1
}

ensure_fast_validation_root() {
  if [[ -n "$fast_validation_root_path" ]]; then
    return 0
  fi

  fast_validation_root_path="$(mktemp -d 2> /dev/null || true)"
  if [[ -z "$fast_validation_root_path" ]]; then
    fast_validation_root_path="/tmp/wallstop-precommit-fast.$$.$RANDOM"
    if ! mkdir -p "$fast_validation_root_path" > /dev/null 2>&1; then
      emit_diagnostic "E_PRECOMMIT_FAST_TEMP_UNAVAILABLE: failed to create temporary directory for staged-blob validation."
      return 1
    fi
  fi
}

extract_precommit_index_blob_for_fast_validation() {
  local staged_file="$1"
  local target_path
  local target_dir

  if ! ensure_fast_validation_root; then
    return 1
  fi

  target_path="${fast_validation_root_path}/index/${staged_file}"
  target_dir="${target_path%/*}"
  if [[ "$target_dir" != "$target_path" ]]; then
    if ! mkdir -p "$target_dir" > /dev/null 2>&1; then
      emit_diagnostic "E_PRECOMMIT_FAST_TEMP_UNAVAILABLE: failed to create temporary parent directory for staged-blob validation. file=${staged_file}"
      return 1
    fi
  fi

  if ! git show ":${staged_file}" > "$target_path"; then
    emit_diagnostic "E_PRECOMMIT_FAST_BLOB_EXTRACT_FAILED: failed to extract staged blob for validation. file=${staged_file}"
    return 1
  fi

  printf '%s\n' "$target_path"
}

validate_precommit_shell_blob() {
  local staged_file="$1"

  if git -C "$repo_root" cat-file blob ":${staged_file}" | bash -n; then
    return 0
  fi

  emit_diagnostic "E_PRECOMMIT_FAST_SHELL_PARSE_FAILED: bash syntax check failed for staged blob. file=${staged_file}"
  return 1
}

ensure_precommit_fast_actionlint_tools() {
  if ! load_fast_tool_resolver; then
    return 1
  fi

  actionlint_path="$(wallstop_resolve_managed_fast_tool "$repo_root" ".tools/native-quality" "actionlint" || true)"

  if [[ -n "$actionlint_path" ]]; then
    return 0
  fi

  if command -v pwsh > /dev/null 2>&1; then
    local remaining_seconds
    if ! remaining_seconds="$(remaining_timeout_seconds "pre-commit fast actionlint bootstrap")"; then
      return 124
    fi

    set +e
    run_with_timeout "$remaining_seconds" "pre-commit fast actionlint bootstrap" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Quality/Invoke-NativeQualityChecks.ps1" -Tool actionlint -EnsureOnly
    local ensure_exit=$?
    set -e
    if [[ $ensure_exit -ne 0 ]]; then
      return "$ensure_exit"
    fi

    actionlint_path="$(wallstop_resolve_managed_fast_tool "$repo_root" ".tools/native-quality" "actionlint" || true)"
    if [[ -n "$actionlint_path" ]]; then
      return 0
    fi
  fi

  emit_diagnostic "E_PRECOMMIT_FAST_NATIVE_TOOL_MISSING: repo-managed actionlint asset is unavailable and automated bootstrap did not make it available. Run validation preflight."
  return 1
}

run_fast_precommit_gate() {
  local staged_files="$1"
  local phase_start_seconds=$SECONDS
  local file
  local extracted_file
  local actionlint_path
  local run_workflow_lint=0
  local workflow_targets=()

  if is_truthy "${WALLSTOP_PRECOMMIT_FAST_WORKFLOW_LINT:-0}"; then
    run_workflow_lint=1
  fi

  while IFS= read -r file; do
    [[ -n "$file" ]] || continue

    case "$file" in
      Scripts/*.sh | .devcontainer/*.sh | .githooks/pre-commit | .githooks/pre-push)
        if ! validate_precommit_shell_blob "$file"; then
          return 1
        fi
        ;;
      .github/workflows/*.yml | .github/workflows/*.yaml)
        if [[ "$run_workflow_lint" -ne 1 ]]; then
          continue
        fi
        if ! extracted_file="$(extract_precommit_index_blob_for_fast_validation "$file")"; then
          return 1
        fi
        workflow_targets+=("$extracted_file")
        ;;
    esac
  done <<< "$staged_files"

  if [[ ${#workflow_targets[@]} -gt 0 ]]; then
    set +e
    ensure_precommit_fast_actionlint_tools
    local ensure_actionlint_exit=$?
    set -e
    if [[ $ensure_actionlint_exit -ne 0 ]]; then
      return "$ensure_actionlint_exit"
    fi

    local remaining_seconds
    if ! remaining_seconds="$(remaining_timeout_seconds "pre-commit fast actionlint")"; then
      return 124
    fi

    run_with_timeout "$remaining_seconds" "pre-commit fast actionlint" "$actionlint_path" -shellcheck "" -pyflakes "" "${workflow_targets[@]}"
    return $?
  fi

  return 0
}

run_safe_autorepair() {
  local staged_files="$1"

  if command -v pwsh > /dev/null 2>&1; then
    if ! has_staged_windows_language_targets "$staged_files"; then
      return 0
    fi

    local remaining_seconds
    if ! remaining_seconds="$(remaining_timeout_seconds "pre-commit safe auto-repair")"; then
      return 124
    fi

    run_with_timeout "$remaining_seconds" "pre-commit safe auto-repair" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Quality/Invoke-PreCommitAutoRepair.ps1"
    return $?
  fi

  return 0
}

precommit_force_recovery_suite=0
set +e
staged_precommit_files="$(get_staged_precommit_files)"
staged_precommit_discovery_exit=$?
set -e
if [[ $staged_precommit_discovery_exit -ne 0 ]]; then
  precommit_force_recovery_suite=1
fi

if [[ "$precommit_force_recovery_suite" -eq 0 && -z "$staged_precommit_files" ]]; then
  emit_runtime_budget_warning "pre-commit no staged files" "$((SECONDS - hook_start_seconds))"
  exit 0
fi

staged_precommit_fast_files=""
if [[ "$precommit_force_recovery_suite" -eq 0 ]]; then
  if ! run_precommit_fast_diff_check; then
    exit 1
  fi

  set +e
  staged_precommit_fast_files="$(get_staged_precommit_fast_files)"
  staged_precommit_fast_discovery_exit=$?
  set -e
  if [[ $staged_precommit_fast_discovery_exit -ne 0 ]]; then
    precommit_force_recovery_suite=1
  fi
fi

if command -v pwsh > /dev/null 2>&1; then
  if run_safe_autorepair "$staged_precommit_fast_files"; then
    :
  else
    safe_autorepair_exit=$?
    exit $safe_autorepair_exit
  fi
fi

if [[ "$precommit_force_recovery_suite" -eq 0 ]] && ! is_truthy "${WALLSTOP_PRECOMMIT_FULL_SUITE:-0}"; then
  if [[ -z "$staged_precommit_fast_files" ]]; then
    emit_runtime_budget_warning "pre-commit fast gate" "$((SECONDS - hook_start_seconds))"
    exit 0
  fi

  run_fast_precommit_gate "$staged_precommit_fast_files"
  fast_gate_exit=$?
  if [[ $fast_gate_exit -eq 0 ]]; then
    emit_runtime_budget_warning "pre-commit fast gate" "$((SECONDS - hook_start_seconds))"
    exit 0
  fi

  exit $fast_gate_exit
fi

if command -v pwsh > /dev/null 2>&1; then
  if remaining_seconds="$(remaining_timeout_seconds "pre-commit hook-stage pre-commit")"; then
    inner_timeout_seconds=$((remaining_seconds - precommit_recovery_shutdown_buffer_seconds))
    required_remaining_seconds=$((precommit_recovery_inner_timeout_seconds + precommit_recovery_shutdown_buffer_seconds))
    if [[ "$inner_timeout_seconds" -lt "$precommit_recovery_inner_timeout_seconds" ]]; then
      emit_recovery_budget_diagnostic "pre-commit hook-stage pre-commit" "$remaining_seconds" "$required_remaining_seconds" "$inner_timeout_seconds"
      exit 124
    fi

    set +e
    run_with_timeout "$remaining_seconds" "pre-commit hook-stage pre-commit" pwsh -NoLogo -NoProfile -File "Scripts/Utils/Quality/Invoke-PreCommitWithRecovery.ps1" -HookStage pre-commit -TimeoutSeconds "$inner_timeout_seconds"
    recovery_exit=$?
    set -e
    if [[ $recovery_exit -eq 0 ]]; then
      exit 0
    fi

    if [[ $recovery_exit -eq 125 ]]; then
      emit_diagnostic "pre-commit CLI bootstrap failed in recovery wrapper; falling back to legacy PowerShell checks."
      emit_diagnostic "Recommended bootstrap:"
      print_precommit_bootstrap_guidance
      emit_diagnostic "      # persist PATH in ~/.bashrc or ~/.zshrc for future shells"
      emit_diagnostic "  pre-commit install --hook-type pre-commit --hook-type pre-push"
      emit_diagnostic "Major changes should close with: pwsh -NoLogo -NoProfile -File Scripts/Utils/Quality/Invoke-FullValidation.ps1"
      run_legacy_validation
      exit $?
    fi

    exit $recovery_exit
  fi

  exit 124
fi

if command -v pre-commit > /dev/null 2>&1; then
  if remaining_seconds="$(remaining_timeout_seconds "pre-commit hook-stage pre-commit")"; then
    set +e
    run_with_timeout "$remaining_seconds" "pre-commit hook-stage pre-commit" pre-commit run --hook-stage pre-commit --show-diff-on-failure --color always
    precommit_hook_exit=$?
    set -e
    exit $precommit_hook_exit
  fi

  exit 124
fi

emit_diagnostic "pre-commit is not installed; falling back to legacy PowerShell checks."
emit_diagnostic "Recommended bootstrap:"
print_precommit_bootstrap_guidance
emit_diagnostic "      # persist PATH in ~/.bashrc or ~/.zshrc for future shells"
emit_diagnostic "  pre-commit install --hook-type pre-commit --hook-type pre-push"
emit_diagnostic "Major changes should close with: pwsh -NoLogo -NoProfile -File Scripts/Utils/Quality/Invoke-FullValidation.ps1"
run_legacy_validation
exit $?
