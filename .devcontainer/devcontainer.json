{
  "name": "wallstop-utils Dev",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-8.0-bookworm@sha256:16a0321c730596c9ee1b1de20369ec454ad9ab963f9b06fc24f88daabe9e44c2",
  "init": true,
  "updateRemoteUserUID": false,
  "remoteUser": "vscode",
  "containerEnv": {
    "WALLSTOP_DEVCONTAINER_ENABLE_CODEX": "1",
    "WALLSTOP_DEVCONTAINER_CODEX_NPM_TIMEOUT_SECONDS": "180",
    "WALLSTOP_DEVCONTAINER_PREFLIGHT_TIMEOUT_SECONDS": "90",
    "WALLSTOP_DEVCONTAINER_PRECOMMIT_PREWARM_TIMEOUT_SECONDS": "90"
  },
  "mounts": [
    "source=${devcontainerId}-pip-cache,target=/home/vscode/.cache/pip,type=volume",
    "source=${devcontainerId}-pre-commit-cache,target=/home/vscode/.cache/pre-commit,type=volume",
    "source=${devcontainerId}-npm-cache,target=/home/vscode/.npm,type=volume"
  ],
  "initializeCommand": "bash .devcontainer/initialize-host.sh \"${localWorkspaceFolder}\"",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "${containerWorkspaceFolder}/Extensions/WallstopPrComments/dist/wallstop-pr-comments-devcontainer.vsix",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-pull-request-github",
        "GitHub.vscode-github-actions",
        "anthropic.claude-code",
        "openai.chatgpt",
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "usernamehw.errorlens",
        "editorconfig.editorconfig",
        "streetsidesoftware.code-spell-checker",
        "yzhang.markdown-all-in-one",
        "davidanson.vscode-markdownlint",
        "bierner.markdown-preview-github-styles",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "redhat.vscode-xml",
        "esbenp.prettier-vscode",
        "timonwong.shellcheck",
        "foxundermoon.shell-format",
        "ms-vscode.powershell",
        "pspester.pester-test",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "mark-wiemer.vscode-autohotkey-plus-plus",
        "thqby.vscode-autohotkey2-lsp",
        "idleberg.applescript",
        "sumneko.lua",
        "ms-azuretools.vscode-docker",
        "PKief.material-icon-theme",
        "enkia.tokyo-night",
        "Catppuccin.catppuccin-vsc",
        "sdras.night-owl",
        "oderwat.indent-rainbow",
        "gruntfuggly.todo-tree",
        "ms-python.vscode-python-envs",
        "ms-python.debugpy",
        "dbaeumer.vscode-eslint",
        "ms-azuretools.vscode-containers",
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime"
      ],
      "settings": {
        "workbench.colorTheme": "Tokyo Night Storm",
        "workbench.iconTheme": "material-icon-theme",
        "editor.fontFamily": "JetBrains Mono, Fira Code, Cascadia Code, monospace",
        "editor.fontLigatures": true,
        "editor.cursorBlinking": "phase",
        "editor.cursorSmoothCaretAnimation": "on",
        "editor.minimap.enabled": true,
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs": true,
        "editor.stickyScroll.enabled": true,
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.fontFamily": "JetBrains Mono, Fira Code, Cascadia Code, monospace",
        "terminal.integrated.gpuAcceleration": "on",
        "git.autofetch": true,
        "git.confirmSync": false,
        "powershell.powerShellDefaultVersion": "PowerShell (Core)",
        "powershell.codeFormatting.whitespaceAfterSeparator": true,
        "shellcheck.enable": true,
        "shellformat.flag": "-i 2 -ci -sr",
        "prettier.requireConfig": false,
        "yaml.format.enable": true,
        "todo-tree.general.tags": ["TODO", "FIXME", "NOTE", "REVIEW"],
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        },
        "ruff.enable": true,
        "[toml]": {
          "editor.defaultFormatter": "tamasfe.even-better-toml"
        },
        "evenBetterToml.formatter.alignEntries": false,
        "[xml]": {
          "editor.defaultFormatter": "redhat.vscode-xml"
        },
        "xml.format.enabled": true,
        "xml.format.splitAttributes": false,
        "[lua]": {
          "editor.defaultFormatter": "sumneko.lua"
        },
        "Lua.diagnostics.enable": true,
        "Lua.completion.enable": true,
        "Lua.workspace.checkThirdParty": false,
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[markdown]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[shellscript]": {
          "editor.defaultFormatter": "foxundermoon.shell-format"
        },
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "autohotkey2.warn.varUnset": true,
        "pester.testsPath": "Tests"
      }
    }
  }
}
